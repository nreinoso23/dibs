<WalkInButton@ButtonBehavior+BoxLayout>:
    orientation: 'vertical'
    canvas.before:
        Color:
            rgba: (0, 0.6, 0, 1) if self.enabled_state else (0.4, 0.4, 0.4, 1)
        RoundedRectangle:
            radius: [16, 16, 16, 16]
            pos: self.pos
            size: self.size
    enabled_state: True

#:import dp kivy.metrics.dp
#:import ClockWidget clock.ClockWidget
#:import WeatherWidget weather.WeatherWidget
#:import RoundedRectangleContainer rounded.RoundedRectangleContainer
#:import SchedulerWidget scheduler.SchedulerWidget
#:import CheckInButton scheduler.CheckInButton
#:import FullDayScheduleWidget scheduler.FullDayScheduleWidget
#:import WalkInWidget scheduler.WalkInWidget

# Custom tile styles
<ThinTile@RoundedRectangleContainer>:
    size_hint_y: None
    height: dp(70)
    background_color: 0.12, 0.12, 0.12, 1
    corner_radius: 12

<BigTile@RoundedRectangleContainer>:
    background_color: 0.18, 0.18, 0.18, 1
    corner_radius: 16

<BigButtonTile@ButtonBehavior+RoundedRectangleContainer>:
    background_color: 0.18, 0.18, 0.18, 1
    corner_radius: 16

# Main Menu Screen
<MenuScreen>:
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(10)
        padding: dp(10)

        # Top row - Quit and Settings (half width each)
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(70)
            spacing: dp(10)

            BigButtonTile:
                on_release:
                    app.root.transition.direction = 'left'
                    app.clear_quit_password()
                    app.root.current = 'password_quit'
                Label:
                    text: "Quit"
                    font_size: '28sp'
                    bold: True
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size

            BigButtonTile:
                on_release:
                    app.root.transition.direction = 'left'
                    app.clear_settings_password()
                    app.root.current = 'password_settings'
                Label:
                    text: "Settings"
                    font_size: '28sp'
                    bold: True
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size

        # Main content - 2 columns
        BoxLayout:
            orientation: 'horizontal'
            spacing: dp(10)

            # Left column - Schedule and Clock/Weather (wider)
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 1.2
                spacing: dp(10)

                # Schedule tile
                BigButtonTile:
                    on_release:
                        app.root.transition.direction = 'left'
                        app.root.current = 'schedule'
                    SchedulerWidget:
                        room_name: "NYU Dibner Study Pod LC 416"

                # Clock & Weather tile
                BigTile:
                    orientation: 'vertical'
                    padding: dp(20)
                    spacing: dp(10)

                    # Date at top
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: 0.25
                        Label:
                            id: date_display
                            text: app.current_date
                            font_size: '32sp'
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                    # Time in middle
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: 0.5
                        Label:
                            id: time_display
                            text: app.current_time
                            font_size: '72sp'
                            bold: True
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

                    # Weather at bottom
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: 0.25
                        spacing: dp(10)
                        Image:
                            id: weather_icon_display
                            source: app.weather_icon_source
                            opacity: 1 if self.source else 0
                            size_hint_x: None
                            width: dp(80)
                            allow_stretch: True
                        Label:
                            text: app.temperature_text
                            font_size: '48sp'
                            bold: True
                            halign: 'left'
                            valign: 'middle'
                            text_size: self.size

            # Right column - Walk In and Check In (narrower, vertical rectangles)
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.8
                spacing: dp(10)

                # Walk In button
                WalkInButton:
                    enabled_state: app.walk_in_enabled
                    on_release: app.goto_walkin_screen() if app.walk_in_enabled else None
                    Label:
                        text: "Walk In"
                        font_size: '56sp'
                        bold: True
                        halign: 'center'
                        valign: 'bottom'
                        text_size: self.size
                        size_hint_y: 0.6
                    Label:
                        text: app.walk_in_status_text
                        font_size: '18sp'
                        color: 0.7, 0.7, 0.7, 1
                        halign: 'center'
                        valign: 'top'
                        text_size: self.size
                        size_hint_y: 0.4

                # Check In button - NOW CONSISTENT WITH WALK IN
                CheckInButton:

# Password for Quit
<PasswordQuitScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        canvas.before:
            Color:
                rgba: 0.1, 0.1, 0.1, 1
            Rectangle:
                size: self.size
                pos: self.pos

        Label:
            text: "Enter Password to Quit"
            font_size: '40sp'
            bold: True
            size_hint_y: None
            height: dp(80)

        # Display for entered password
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(90)
            padding: dp(10)
            canvas.before:
                Color:
                    rgba: 0.2, 0.2, 0.2, 1
                RoundedRectangle:
                    size: self.size
                    pos: self.pos
                    radius: [10]
            Label:
                id: password_quit_display
                text: "*" * len(app.quit_password_input)
                font_size: '36sp'
                halign: 'center'
                valign: 'middle'
                text_size: self.size

        # Custom alphanumeric keyboard
        GridLayout:
            cols: 10
            spacing: dp(5)
            size_hint_y: 0.5

            # Numbers row
            Button:
                text: "1"
                font_size: '28sp'
                on_release: app.add_to_quit_password("1")
            Button:
                text: "2"
                font_size: '28sp'
                on_release: app.add_to_quit_password("2")
            Button:
                text: "3"
                font_size: '28sp'
                on_release: app.add_to_quit_password("3")
            Button:
                text: "4"
                font_size: '28sp'
                on_release: app.add_to_quit_password("4")
            Button:
                text: "5"
                font_size: '28sp'
                on_release: app.add_to_quit_password("5")
            Button:
                text: "6"
                font_size: '28sp'
                on_release: app.add_to_quit_password("6")
            Button:
                text: "7"
                font_size: '28sp'
                on_release: app.add_to_quit_password("7")
            Button:
                text: "8"
                font_size: '28sp'
                on_release: app.add_to_quit_password("8")
            Button:
                text: "9"
                font_size: '28sp'
                on_release: app.add_to_quit_password("9")
            Button:
                text: "0"
                font_size: '28sp'
                on_release: app.add_to_quit_password("0")

            # First letter row
            Button:
                text: "Q"
                font_size: '28sp'
                on_release: app.add_to_quit_password("q")
            Button:
                text: "W"
                font_size: '28sp'
                on_release: app.add_to_quit_password("w")
            Button:
                text: "E"
                font_size: '28sp'
                on_release: app.add_to_quit_password("e")
            Button:
                text: "R"
                font_size: '28sp'
                on_release: app.add_to_quit_password("r")
            Button:
                text: "T"
                font_size: '28sp'
                on_release: app.add_to_quit_password("t")
            Button:
                text: "Y"
                font_size: '28sp'
                on_release: app.add_to_quit_password("y")
            Button:
                text: "U"
                font_size: '28sp'
                on_release: app.add_to_quit_password("u")
            Button:
                text: "I"
                font_size: '28sp'
                on_release: app.add_to_quit_password("i")
            Button:
                text: "O"
                font_size: '28sp'
                on_release: app.add_to_quit_password("o")
            Button:
                text: "P"
                font_size: '28sp'
                on_release: app.add_to_quit_password("p")

            # Second letter row
            Button:
                text: "A"
                font_size: '28sp'
                on_release: app.add_to_quit_password("a")
            Button:
                text: "S"
                font_size: '28sp'
                on_release: app.add_to_quit_password("s")
            Button:
                text: "D"
                font_size: '28sp'
                on_release: app.add_to_quit_password("d")
            Button:
                text: "F"
                font_size: '28sp'
                on_release: app.add_to_quit_password("f")
            Button:
                text: "G"
                font_size: '28sp'
                on_release: app.add_to_quit_password("g")
            Button:
                text: "H"
                font_size: '28sp'
                on_release: app.add_to_quit_password("h")
            Button:
                text: "J"
                font_size: '28sp'
                on_release: app.add_to_quit_password("j")
            Button:
                text: "K"
                font_size: '28sp'
                on_release: app.add_to_quit_password("k")
            Button:
                text: "L"
                font_size: '28sp'
                on_release: app.add_to_quit_password("l")
            Button:
                text: "⌫"
                font_size: '32sp'
                on_release: app.backspace_quit_password()

            # Third letter row
            Button:
                text: "Z"
                font_size: '28sp'
                on_release: app.add_to_quit_password("z")
            Button:
                text: "X"
                font_size: '28sp'
                on_release: app.add_to_quit_password("x")
            Button:
                text: "C"
                font_size: '28sp'
                on_release: app.add_to_quit_password("c")
            Button:
                text: "V"
                font_size: '28sp'
                on_release: app.add_to_quit_password("v")
            Button:
                text: "B"
                font_size: '28sp'
                on_release: app.add_to_quit_password("b")
            Button:
                text: "N"
                font_size: '28sp'
                on_release: app.add_to_quit_password("n")
            Button:
                text: "M"
                font_size: '28sp'
                on_release: app.add_to_quit_password("m")
            Button:
                text: "Clear"
                font_size: '24sp'
                on_release: app.clear_quit_password()
                background_color: 0.8, 0.3, 0, 1

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(80)
            spacing: dp(10)

            Button:
                text: "Submit"
                font_size: '32sp'
                bold: True
                background_color: 0, 0.6, 0, 1
                on_release: app.verify_quit_password(app.quit_password_input)

            Button:
                text: "Back"
                font_size: '28sp'
                background_color: 0.3, 0.3, 0.3, 1
                on_release: app.goto_menu()

