# Confirm Quit Screen
<ConfirmQuitScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(40)
        spacing: dp(20)
        canvas.before:
            Color:
                rgba: 0.1, 0.1, 0.1, 1
            Rectangle:
                size: self.size
                pos: self.pos

        Widget:
            size_hint_y: 0.3

        Label:
            text: "Are you sure you want to quit?"
            font_size: '40sp'
            bold: True
            size_hint_y: None
            height: dp(100)

        Widget:
            size_hint_y: 0.2

        Button:
            text: "Yes, Quit"
            size_hint_y: None
            height: dp(90)
            font_size: '36sp'
            bold: True
            background_color: 0.8, 0, 0, 1
            on_release: app.quit_app()

        Button:
            text: "No, Go Back"
            size_hint_y: None
            height: dp(90)
            font_size: '36sp'
            bold: True
            background_color: 0, 0.6, 0, 1
            on_release:
                app.root.transition.direction = 'right'
                app.root.current = 'menu'

        Widget:
            size_hint_y: 0.3

# Schedule Screen (Full Day)
<ScheduleScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        canvas.before:
            Color:
                rgba: 0.1, 0.1, 0.1, 1
            Rectangle:
                size: self.size
                pos: self.pos

        FullDayScheduleWidget:
            room_name: "NYU Dibner Study Pod LC 416"

        Button:
            text: "Back to Menu"
            size_hint_y: None
            height: dp(80)
            font_size: '28sp'
            on_release: app.goto_menu()

# Check In Screen
<CheckInScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        canvas.before:
            Color:
                rgba: 0.1, 0.1, 0.1, 1
            Rectangle:
                size: self.size
                pos: self.pos

        # Top section - Title and status
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(100)
            spacing: dp(5)
            
            Label:
                text: "Check In - Enter Your N Number"
                font_size: '44sp'
                bold: True
                size_hint_y: None
                height: dp(50)
            
            Label:
                text: app.checkin_status_text
                font_size: '28sp'
                size_hint_y: None
                height: dp(40)
                color: 0.8, 0.8, 0.8, 1

        # N Number display
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(100)
            padding: [dp(50), 0, dp(50), 0]
            
            BoxLayout:
                canvas.before:
                    Color:
                        rgba: 0.2, 0.2, 0.2, 1
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [12]
                Label:
                    id: n_number_display
                    text: app.n_number_input if len(app.n_number_input) > 1 else "N________"
                    font_size: '52sp'
                    bold: True
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size
                    color: (1, 1, 1, 1) if len(app.n_number_input) > 1 else (0.5, 0.5, 0.5, 1)

        Widget:
            size_hint_y: 0.02

        # Main content area - Keypad on left, buttons on right
        BoxLayout:
            orientation: 'horizontal'
            spacing: dp(30)
            padding: [dp(30), 0, dp(30), 0]

            # Left side - Number pad and controls
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(15)
                size_hint_x: 0.70

                # 3x3 grid for numbers 1-9
                GridLayout:
                    cols: 3
                    spacing: dp(15)
                    size_hint_y: 0.75

                    # Row 1: 1 2 3
                    Button:
                        id: num_1
                        text: "1"
                        font_size: '64sp'
                        bold: True
                        on_release: app.add_to_n_number("1")
                    Button:
                        id: num_2
                        text: "2"
                        font_size: '64sp'
                        bold: True
                        on_release: app.add_to_n_number("2")
                    Button:
                        id: num_3
                        text: "3"
                        font_size: '64sp'
                        bold: True
                        on_release: app.add_to_n_number("3")

                    # Row 2: 4 5 6
                    Button:
                        id: num_4
                        text: "4"
                        font_size: '64sp'
                        bold: True
                        on_release: app.add_to_n_number("4")
                    Button:
                        id: num_5
                        text: "5"
                        font_size: '64sp'
                        bold: True
                        on_release: app.add_to_n_number("5")
                    Button:
                        id: num_6
                        text: "6"
                        font_size: '64sp'
                        bold: True
                        on_release: app.add_to_n_number("6")

                    # Row 3: 7 8 9
                    Button:
                        id: num_7
                        text: "7"
                        font_size: '64sp'
                        bold: True
                        on_release: app.add_to_n_number("7")
                    Button:
                        id: num_8
                        text: "8"
                        font_size: '64sp'
                        bold: True
                        on_release: app.add_to_n_number("8")
                    Button:
                        id: num_9
                        text: "9"
                        font_size: '64sp'
                        bold: True
                        on_release: app.add_to_n_number("9")

                # Bottom row: Clear, 0, Backspace
                BoxLayout:
                    orientation: 'horizontal'
                    spacing: dp(15)
                    size_hint_y: 0.25

                    Button:
                        id: clear_btn
                        text: "Clear"
                        font_size: '36sp'
                        bold: True
                        on_release: app.clear_n_number()
                    Button:
                        id: num_0
                        text: "0"
                        font_size: '64sp'
                        bold: True
                        on_release: app.add_to_n_number("0")
                    Button:
                        id: backspace_btn
                        text: "⌫"
                        font_size: '52sp'
                        bold: True
                        on_release: app.backspace_n_number()

            # Right side - Back and Submit buttons stacked
            BoxLayout:
                orientation: 'vertical'
                spacing: dp(15)
                size_hint_x: 0.30

                Button:
                    id: back_btn
                    text: "Back"
                    font_size: '44sp'
                    bold: True
                    on_release: app.goto_menu()

                Button:
                    id: submit_btn
                    text: "Submit"
                    font_size: '44sp'
                    bold: True
                    background_color: 0, 0.7, 0, 1
                    on_release: app.submit_n_number()

        Widget:
            size_hint_y: 0.02

<WalkInScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.1, 0.1, 0.1, 1
            Rectangle:
                size: self.size
                pos: self.pos

        Label:
            text: "Walk-In Booking"
            font_size: '36sp'
            bold: True
            size_hint_y: None
            height: dp(60)

        Widget:
            size_hint_y: 0.05

        Label:
            text: "Select Duration (minutes)"
            font_size: '28sp'
            size_hint_y: None
            height: dp(50)

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(120)
            spacing: dp(15)
            padding: [dp(20), 0]

            Label:
                text: "15"
                font_size: '24sp'
                size_hint_x: None
                width: dp(50)
                halign: 'center'
                valign: 'middle'
                text_size: self.size

            Slider:
                id: duration_slider
                min: 15
                max: min(120, app.max_walk_in_duration)
                value: 60
                step: 15
                size_hint_x: 1
                on_value: root.ids.duration_display.text = f"{int(self.value)} minutes"

            Label:
                text: str(int(min(120, app.max_walk_in_duration)))
                font_size: '24sp'
                size_hint_x: None
                width: dp(50)
                halign: 'center'
                valign: 'middle'
                text_size: self.size

        Label:
            id: duration_display
            text: "60 minutes"
            font_size: '40sp'
            bold: True
            size_hint_y: None
            height: dp(80)

        Label:
            text: f"Appointment ends at: {app.walk_in_end_time}"
            font_size: '24sp'
            size_hint_y: None
            height: dp(50)
            color: 0.9, 0.9, 0.9, 1

        Label:
            text: app.walk_in_limit_reason
            font_size: '18sp'
            size_hint_y: None
            height: dp(45)
            color: 0.7, 0.7, 0.7, 1

        Widget:
            size_hint_y: 0.1

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(75)
            spacing: dp(10)

            Button:
                text: "Need More Time?"
                font_size: '24sp'
                on_release:
                    app.root.transition.direction = 'left'
                    app.root.current = 'walkin_detailed'

            Button:
                text: "Confirm"
                font_size: '32sp'
                bold: True
                background_color: 0, 0.6, 0, 1
                on_release: app.confirm_walkin(int(duration_slider.value))

        Button:
            text: "Back"
            size_hint_y: None
            height: dp(70)
            font_size: '28sp'
            on_release: app.goto_menu()

# Walk-In Detailed Screen - Hour/Minute picker (for long durations)
<WalkInDetailedScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(10)
        canvas.before:
            Color:
                rgba: 0.1, 0.1, 0.1, 1
            Rectangle:
                size: self.size
                pos: self.pos

        Label:
            text: "Walk-In Booking"
            font_size: '36sp'
            bold: True
            size_hint_y: None
            height: dp(60)

        Widget:
            size_hint_y: 0.05

        # Hours selector
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(100)
            spacing: dp(15)

            Label:
                text: "Hours:"
                font_size: '28sp'
                size_hint_x: 0.25
                halign: 'right'
                valign: 'middle'
                text_size: self.size

            Button:
                text: "−"
                font_size: '48sp'
                bold: True
                size_hint_x: 0.2
                on_release: app.decrease_walk_in_hours()

            Label:
                text: str(app.walk_in_hours)
                font_size: '48sp'
                bold: True
                size_hint_x: 0.3
                halign: 'center'
                valign: 'middle'
                text_size: self.size

            Button:
                text: "+"
                font_size: '48sp'
                bold: True
                size_hint_x: 0.2
                on_release: app.increase_walk_in_hours()

        # Minutes selector
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(100)
            spacing: dp(15)

            Label:
                text: "Minutes:"
                font_size: '28sp'
                size_hint_x: 0.25
                halign: 'right'
                valign: 'middle'
                text_size: self.size

            Button:
                text: "−"
                font_size: '48sp'
                bold: True
                size_hint_x: 0.2
                on_release: app.decrease_walk_in_minutes()

            Label:
                text: str(app.walk_in_minutes)
                font_size: '48sp'
                bold: True
                size_hint_x: 0.3
                halign: 'center'
                valign: 'middle'
                text_size: self.size

            Button:
                text: "+"
                font_size: '48sp'
                bold: True
                size_hint_x: 0.2
                on_release: app.increase_walk_in_minutes()

        Widget:
            size_hint_y: 0.05

        # Total duration display
        Label:
            text: f"Total Duration: {app.walk_in_hours}h {app.walk_in_minutes}m"
            font_size: '28sp'
            bold: True
            size_hint_y: None
            height: dp(50)

        Label:
            text: f"Appointment ends at: {app.walk_in_end_time_detailed}"
            font_size: '24sp'
            size_hint_y: None
            height: dp(50)
            color: 0.9, 0.9, 0.9, 1

        Label:
            text: app.walk_in_limit_reason
            font_size: '18sp'
            size_hint_y: None
            height: dp(45)
            color: 0.7, 0.7, 0.7, 1

        Widget:
            size_hint_y: 0.1

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(75)
            spacing: dp(10)

            Button:
                text: "Use Slider"
                font_size: '24sp'
                on_release:
                    app.root.transition.direction = 'right'
                    app.root.current = 'walkin'

            Button:
                text: "Confirm Walk-In"
                font_size: '28sp'
                bold: True
                background_color: 0, 0.6, 0, 1
                on_release: app.confirm_walkin_detailed()

        Button:
            text: "Back to Menu"
            size_hint_y: None
            height: dp(65)
            font_size: '26sp'
            on_release: app.goto_menu()

